# Copie este arquivo para .env e preencha a chave.
# A chave da API da Anthropic voce pega em https://console.anthropic.com (menu API Keys).
ANTHROPIC_API_KEY=

# Connection string do banco Postgres no Supabase. Pegue em:
# Painel do Supabase > seu projeto > Project Settings > Database > Connection string (URI).
# Formato: postgresql://postgres.[ref-do-projeto]:[senha]@[host]:5432/postgres
DATABASE_URL=

# Opcional. Para baratear, troque o modelo por Sonnet:
# GUARDIAO_MODELO=claude-sonnet-5
